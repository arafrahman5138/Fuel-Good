{
  "expo": {
    "name": "Fuel Good",
    "slug": "fuelgood",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fuelgood",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fuelgood.ios",
      "usesAppleSignIn": true,
      "splash": {
        "image": "./assets/images/splash-icon-light.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "dark": {
          "image": "./assets/images/splash-icon-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Fuel Good uses the camera to scan barcodes and capture product labels.",
        "NSPhotoLibraryUsageDescription": "Fuel Good uses your photo library so you can attach ingredient and nutrition label photos.",
        "NSPhotoLibraryAddUsageDescription": "Fuel Good may save temporary label images you choose during scanning.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "fuelgood",
              "com.fuelgood.ios"
            ]
          }
        ]
      }
    },
    "android": {
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.fuelgood.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Fuel Good uses the camera to scan barcodes and capture product labels."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fuel Good uses your photo library so you can attach ingredient and nutrition label photos.",
          "cameraPermission": "Fuel Good uses the camera so you can capture ingredient and nutrition label photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/fd207039-72fe-4e1c-a344-495e48d4bc4f"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd207039-72fe-4e1c-a344-495e48d4bc4f"
      }
    }
  }
}
