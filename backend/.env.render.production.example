DATABASE_URL=postgresql://postgres.USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
CORS_ALLOWED_ORIGINS=https://api.fuelgood.app,https://fuelgood.app
RUN_NOTIFICATION_SCHEDULER=false
NOTIFICATION_RUNNER_SECRET=replace-with-a-long-random-secret-for-supabase-cron
NOTIFICATION_CRON_BATCH_SIZE=100
NOTIFICATION_CRON_USER_LIMIT=250
RUN_STARTUP_SEEDING=false
SYNC_OFFICIAL_MEALS_ON_STARTUP=true
ALLOW_DEV_DB_BOOTSTRAP=false
LLM_PROVIDER=gemini
CHAT_MODEL=gemini-2.5-flash
SCAN_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

GOOGLE_API_KEY=replace-with-your-google-ai-api-key
GEMINI_MODEL=gemini-2.5-flash

APPLE_BUNDLE_ID=com.fuelgood.ios
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-oauth-client-secret

SUPPORT_EMAIL=support@fuelgood.app
RESEND_API_KEY=replace-with-your-resend-api-key
EMAIL_FROM=noreply@fuelgood.app
EMAIL_REPLY_TO=support@fuelgood.app
PRIVACY_POLICY_URL=https://fuelgood.app/privacy
TERMS_URL=https://fuelgood.app/terms
SUPPORT_URL=https://fuelgood.app/support

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_STORAGE_MEAL_SCANS_BUCKET=meal-scans
SUPABASE_STORAGE_LABEL_SCANS_BUCKET=label-scans
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

EXPO_PUSH_ACCESS_TOKEN=

REVENUECAT_SECRET_API_KEY=replace-with-your-revenuecat-secret-api-key
REVENUECAT_IOS_API_KEY=replace-with-your-revenuecat-ios-sdk-key
REVENUECAT_WEBHOOK_AUTHORIZATION=replace-with-a-long-random-webhook-secret
REVENUECAT_ENTITLEMENT_ID=Fuel Good Premium
REVENUECAT_OFFERING_ID=default
REVENUECAT_MONTHLY_PRODUCT_ID=monthly
REVENUECAT_ANNUAL_PRODUCT_ID=yearly
REVENUECAT_LIFETIME_PRODUCT_ID=lifetime
REVENUECAT_TRIAL_DAYS=7
CHAT_QUOTA_EXEMPT_EMAILS=

LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=true
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20
APP_STORE_MANAGE_SUBSCRIPTIONS_URL=https://apps.apple.com/account/subscriptions
