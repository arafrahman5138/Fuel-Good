# Runtime
ENVIRONMENT=development
RUN_NOTIFICATION_SCHEDULER=false
RUN_STARTUP_SEEDING=false

# PostgreSQL
DATABASE_URL=postgresql://realfood:realfood_local@localhost:5432/fuelgood
# Production example:
# DATABASE_URL=postgresql://postgres.USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Security
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=90
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=true

# Public support/legal metadata
SUPPORT_EMAIL=support@fuelgood.com
PRIVACY_POLICY_URL=https://fuelgood.com/privacy
TERMS_URL=https://fuelgood.com/terms
SUPPORT_URL=https://fuelgood.com/support

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_MEAL_SCANS_BUCKET=meal-scans
SUPABASE_STORAGE_LABEL_SCANS_BUCKET=label-scans
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Billing / RevenueCat
REVENUECAT_SECRET_API_KEY=
REVENUECAT_IOS_API_KEY=
REVENUECAT_WEBHOOK_AUTHORIZATION=
REVENUECAT_ENTITLEMENT_ID=Fuel Good Premium
REVENUECAT_OFFERING_ID=default
REVENUECAT_MONTHLY_PRODUCT_ID=monthly
REVENUECAT_ANNUAL_PRODUCT_ID=yearly
REVENUECAT_LIFETIME_PRODUCT_ID=lifetime
REVENUECAT_TRIAL_DAYS=7
APP_STORE_MANAGE_SUBSCRIPTIONS_URL=https://apps.apple.com/account/subscriptions
CHAT_QUOTA_EXEMPT_EMAILS=arahman.usa500@gmail.com

# Social auth
SOCIAL_AUTH_ENABLED=true
APPLE_BUNDLE_ID=com.fuelgood.app
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# AI and food APIs
LLM_PROVIDER=gemini
CHAT_MODEL=gemini-2.5-flash
SCAN_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768
GOOGLE_API_KEY=your-google-api-key
# Optional alias supported by backend:
# GEMINI_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OLLAMA_HOST=127.0.0.1:11434
USDA_API_KEY=your-usda-api-key
SPOONACULAR_API_KEY=your-spoonacular-api-key

# Push notifications
EXPO_PUSH_ACCESS_TOKEN=
